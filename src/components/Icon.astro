---
import { ICONS } from '../data/icons.js';

const { name, size = 18, stroke = 2, class: className, style } = Astro.props;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={stroke}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  style={style}
  set:html={ICONS[name]}
/>
